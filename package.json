{
  "name": "super-terminal",
  "version": "0.1.0",
  "description": "A modern multi-terminal manager with splits, tabs, and grid layouts",
  "author": "Tomas Pinal",
  "main": "dist/main/index.js",
  "build": {
    "appId": "com.tomaspinal.superterminal",
    "productName": "SuperTerminal",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ]
  },
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && (tsc -p tsconfig.main.json --watch & vite & sleep 2 && electron dist/main/index.js --dev)",
    "build": "tsc -p tsconfig.main.json && vite build",
    "package": "npm run build && electron-builder --mac",
    "start": "electron dist/main/index.js",
    "postinstall": "electron-rebuild"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
