{
  "name": "super-terminal",
  "version": "0.2.0",
  "description": "A modern multi-terminal manager with splits, tabs, and grid layouts",
  "author": "Tomas Pinal",
  "main": "dist/main/index.js",
  "build": {
    "appId": "com.tomaspinal.superterminal",
    "productName": "SuperTerminal",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ]
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ]
  },
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && node scripts/dev.mjs",
    "build": "tsc -p tsconfig.main.json && vite build",
    "package": "npm run build && electron-builder --mac",
    "start": "electron dist/main/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "postinstall": "electron-rebuild"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.3",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
